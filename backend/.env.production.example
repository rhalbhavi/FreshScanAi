### PRODUCTION ENV — Backend (Hugging Face Spaces / Railway / Render)
###
### Copy this to .env.production and fill in the values.
### In HF Spaces: set these via Settings → Repository secrets / Variables.
###
### NEVER commit real secrets to Git. This file is a template only.

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=your_supabase_anon_key
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# ── URLs ──────────────────────────────────────────────────────────────────────
# FRONTEND_URL: the Vercel URL of the frontend — used to redirect after OAuth.
# Must NOT have a trailing slash.
FRONTEND_URL=https://fresh-scanai.vercel.app

# API_BASE_URL: the public URL of THIS backend (HF Spaces API endpoint).
# Example: https://jpdevhub-freshscan-backend.hf.space
# Used to build the Google OAuth callback URL.
API_BASE_URL=https://your-hf-space-name.hf.space

# ── Auth ──────────────────────────────────────────────────────────────────────
# NEVER set these to true in production.
DEV_BYPASS_AUTH=false
DEV_BYPASS_TOKEN=

# ── CORS ──────────────────────────────────────────────────────────────────────
# false = only FRONTEND_URL is allowed. true = open (dev only).
CORS_ALLOW_ALL=false
