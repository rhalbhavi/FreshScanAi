### DEVELOPMENT ENV — Backend (local FastAPI on port 8000)
###
### Copy this to .env (git-ignored) and run: uvicorn main:app --reload

# ── Supabase (use local Supabase CLI instance) ────────────────────────────────
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_KEY=your_local_supabase_anon_key
SUPABASE_SERVICE_KEY=your_local_supabase_service_role_key

# ── URLs ──────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
API_BASE_URL=http://localhost:8000

# ── Auth ──────────────────────────────────────────────────────────────────────
# Set DEV_BYPASS_AUTH=true to skip Google OAuth in local dev.
# The frontend will show a "Dev bypass" button on the /auth page.
DEV_BYPASS_AUTH=true
DEV_BYPASS_TOKEN=dev-local-bypass-token

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ALLOW_ALL=true
