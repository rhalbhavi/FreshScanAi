{
  "name": "frontend",
  "private": true,
  "version": "1.3.0",
  "type": "module",
  "scripts": {
    "setup": "sh scripts/dev-setup.sh",
    "dev": "concurrently --names \"UI,API\" --prefix-colors \"green,cyan\" \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:frontend": "vite",
    "dev:backend": "node -e \"const {execSync}=require('child_process');const cmd=process.platform==='win32'?'scripts\\\\start-backend.bat':'sh scripts/start-backend.sh';execSync(cmd,{stdio:'inherit',shell:true})\"",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "supabase:start": "cd backend && supabase start",
    "supabase:stop": "cd backend && supabase stop",
    "supabase:reset": "cd backend && supabase db reset"
  },
  "dependencies": {
    "framer-motion": "^11.2.10",
    "i18next": "^23.11.5",
    "i18next-browser-languagedetector": "^8.0.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.395.0",
    "onnxruntime-web": "^1.18.0",
    "posthog-js": "^1.141.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hot-toast": "^2.4.1",
    "react-i18next": "^14.1.2",
    "react-joyride": "^2.8.2",
    "react-leaflet": "^4.2.1",
    "react-router-dom": "^6.23.1"
  },
  "devDependencies": {
    "@types/leaflet": "^1.9.12",
    "@types/node": "^20.14.2",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@tailwindcss/vite": "^4.0.0-alpha.13",
    "tailwindcss": "^4.0.0-alpha.13",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react": "^7.34.2",
    "eslint-plugin-react-refresh": "^0.4.7",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "typescript": "~5.3.3",
    "vite": "^5.3.1",
    "vite-plugin-pwa": "^0.20.0",
    "workbox-window": "^7.1.0"
  }
}
